@model Bowling_Tournament_Registration_System.Ui.ViewModels.EditTournamentVm

<h2>Edit Tournament</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name" />
        <span asp-validation-for="Name"></span>
    </div>

    <div>
        <label asp-for="Date"></label>
        <input asp-for="Date" type="date" />
        <span asp-validation-for="Date"></span>
    </div>

    <div>
        <label asp-for="Location"></label>
        <input asp-for="Location" />
        <span asp-validation-for="Location"></span>
    </div>

    <div>
        <label asp-for="Capacity"></label>
        <input asp-for="Capacity" type="number" />
        <span asp-validation-for="Capacity"></span>
    </div>

    <button type="submit">Update Tournament</button>
</form>