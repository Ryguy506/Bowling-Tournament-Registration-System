@model Bowling_Tournament_Registration_System.Ui.ViewModels.EditTeamVm

@{
    ViewData["Title"] = "Edit Team";
}

<div class="container mt-4">
    <h2 class="mb-4">Edit Team</h2>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Team Info</h5>
            <form method="post" asp-action="UpdateTeam" asp-controller="AdminTeam">
                <input type="hidden" name="Id" value="@Model.Team.Id" />

                <div class="mb-3">
                    <label class="form-label">Team Name</label>
                    <input type="text" name="TeamName" value="@Model.Team.TeamName" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Division</label>
                    <input type="number" name="DivisionId" value="@Model.Team.DivisionId" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary">Save Changes</button>
            </form>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Players</h5>

            @if (!Model.PlayersOnTeam.Any())
            {
                <p class="text-muted">No players on this team.</p>
            }
            else
            {
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var player in Model.PlayersOnTeam)
                        {
                            <tr>
                                <td>@player.Name</td>
                                <td>
                                    <form method="post" asp-action="RemovePlayer" asp-controller="AdminTeam">
                                        <input type="hidden" name="playerId" value="@player.Id" />
                                        <input type="hidden" name="teamId" value="@Model.Team.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

        
            <h6 class="mt-3">Add Player</h6>
            <form method="post" asp-action="AddPlayer" asp-controller="AdminTeam">
                <input type="hidden" name="teamId" value="@Model.Team.Id" />
                <div class="input-group">
                    <select name="playerId" class="form-select">
                        @foreach (var player in Model.AvailablePlayers)
                        {
                            <option value="@player.Id">@player.Name</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-success">Add</button>
                </div>
            </form>
        </div>
    </div>

    <a asp-action="Index" asp-controller="AdminTeam" class="btn btn-secondary">Back to Teams</a>
</div>