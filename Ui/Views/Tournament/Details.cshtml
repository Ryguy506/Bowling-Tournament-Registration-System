 @model Bowling_Tournament_Registration_System.Ui.ReadModels.TournamentDetailsOption;

@{
    ViewData["Title"] = "Tournament Details";
}

<div class="container mt-4">
    <h2 class="mb-4">@Model.Name</h2>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Tournament Info</h5>
            <dl class="row">
                <dt class="col-sm-3">Date</dt>
                <dd class="col-sm-9">@Model.Date.ToShortDateString()</dd>

                <dt class="col-sm-3">Location</dt>
                <dd class="col-sm-9">@Model.Location</dd>

                <dt class="col-sm-3">Capacity</dt>
                <dd class="col-sm-9">@Model.Capacity</dd>

                <dt class="col-sm-3">Spots Remaining</dt>
                <dd class="col-sm-9">@Model.SpotsRemaining</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @if (Model.RegistrationOpen)
                    {
                    <span class="badge bg-success">Open</span>
                    }
                    else
                    {
                    <span class="badge bg-danger">Closed</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Registered Teams</h5>
            @if (!Model.RegisteredTeams.Any())
            {
            <p class="text-muted">No teams registered yet.</p>
            }
            else
            {
            <ul class="list-group">
                @foreach (var team in Model.RegisteredTeams)
                    {
                <li class="list-group-item">@team</li>
                    }
            </ul>
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Waitlisted Teams</h5>

            @if (!Model.WaitlistedTeams.Any())
        {
            <p class="text-muted">No teams on the waitlist.</p>
        }
        else
        {
            <ul class="list-group">
                @foreach (var team in Model.WaitlistedTeams)
                {
                <li class="list-group-item">
                    @team.Position - @team.TeamName
                </li>
                }
            </ul>
        }
        </div>
    </div>

    @if (Model.RegistrationOpen)
    {
    <a asp-action="Register" asp-route-id="@Model.Id" class="btn btn-primary">Register Team</a>
    }

    <a asp-action="Index" class="btn btn-secondary ms-2">Back to Tournaments</a>
</div>
