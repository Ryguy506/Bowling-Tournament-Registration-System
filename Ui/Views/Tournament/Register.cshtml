@model Bowling_Tournament_Registration_System.Ui.ViewModels.RegisterTeamVm;

<h2>Register Team</h2>

<form asp-action="Register" method="post">
    <input type="hidden" asp-for="TournamentId" />

    <table>
        <thead>
            <tr>
                <th>Select</th>
                <th>Team</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var team in Model.Teams)
            {
                <tr>
                    <td>
                        @if (team.IsEligible)
                        {
                            <input type="radio" asp-for="SelectedTeamId" value="@team.TeamId" />
                        }
                        else
                        {
                            <input type="radio" disabled />
                        }
                    </td>
                    <td>@team.TeamName </td>
                    <td>
                        @if (team.IsEligible)
                        {
                            <span>Eligible</span>
                        }
                        else
                        {
                            <span>@team.ReasonNotEligible</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button type="submit">Register</button>
</form>

<div style="color:red;">
    @Html.ValidationSummary()
</div>
